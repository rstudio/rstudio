# Copy to .env.local and fill in the values you want.
# .env.local is gitignored. Values here are loaded by playwright.config.ts
# before any process.env reads. Vars already set in the shell win over
# values in this file.
#
# Every key below is listed uncommented so the available keys are easy to
# scan; most default to empty/unset behavior when left blank. Three keys
# (PW_RSTUDIO_MODE, PW_RSTUDIO_EDITION, PW_SANDBOX_ROOT) validate their value
# and reject an empty string: the first two are pre-filled with their real
# default (change the value, don't blank it out); PW_SANDBOX_ROOT, whose
# default os.tmpdir() has no literal value, stays commented in its section
# below instead.
#
# Point dotenv at a different file with PW_ENV_FILE=<path> on the command line.

# --- Mode and edition ---
PW_RSTUDIO_MODE=desktop
PW_RSTUDIO_EDITION=os

# --- Desktop mode ---
PW_CDP_PORT=
PW_RSTUDIO_EXTRA_ARGS=
PW_RSTUDIO_PREFS_OVERRIDE=

# --- Server mode (PW_RSTUDIO_MODE=server) ---
# When PW_RSTUDIO_SERVER_URL is unset, the fixture spawns a private
# rserver-dev per worker (HOME + data dirs sandboxed under PW_SANDBOX).
# Set PW_RSTUDIO_SERVER_URL to point at an external server (e.g. CI).
PW_RSTUDIO_SERVER_URL=
PW_RSTUDIO_SERVER_PORT=
PW_RSTUDIO_SERVER_USER=
PW_RSTUDIO_SERVER_PASSWORD=
PW_RSTUDIO_SERVER_LOGIN_TIMEOUT=
# Override the in-tree rserver paths if your build lives elsewhere.
PW_RSERVER_BIN=
PW_RSERVER_CONF=

# --- AI authentication (setup project) ---
# The setup project auto-detects how to provision each AI provider's
# credentials independently: if the provider's account credentials below are
# set, it runs that provider's live sign-in flow; otherwise it copies the
# local credential store (sign in locally first). Leave a provider's
# credentials blank to use its local store. See the README's Environment
# Variables table for details.
POSIT_EMAIL=
POSIT_PASSWORD=
# GitHub login (username, not email) and password of a dedicated Copilot test
# account with Copilot access (e.g. Copilot Free enabled). The TOTP secret
# (base32) is only needed if the account has an authenticator app enrolled.
COPILOT_USER=
COPILOT_PASSWORD=
COPILOT_TOTP_SECRET=
# Global seed kill-switch: block copying real credentials from the local
# machine into the sandbox (Copilot config-dir copy, Posit AI token-store
# copy). The sign-in flows are unaffected.
PW_SANDBOX_NO_SEED_CREDENTIALS=
# Strict provisioning: fail the run when the setup ends with a provider
# unprovisioned, instead of letting that provider's tests skip. Applies to
# both Posit AI and GitHub Copilot. For runs that expect credentials to be
# present (e.g. CI once secrets are wired in).
PW_AI_AUTH_STRICT=
# Opt-in page capture for the sign-in flows: write a numbered screenshot and
# HTML of every page the flow visits (plus the final state) into
# test-results/, for debugging provider login-page changes. Applies to all
# provider flows automatically. Off by default because credentials are typed
# into those pages (the captures can include the username).
PW_DEBUG_AUTH=

# --- Sandbox ---
# Parent directory for the per-invocation sandbox (default: os.tmpdir(), which
# has no single literal value here -- leave commented to use it; blank breaks).
# PW_SANDBOX_ROOT=/path/to/parent/dir
PW_SANDBOX_ROOT_CREATE=
PW_SANDBOX_SKIP_CLEANUP=
