{
  "name": "rstudio-playwright-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "npm run test:desktop",
    "test:desktop": "tsx scripts/test.ts --project=desktop",
    "test:desktop-dev": "tsx scripts/desktop-dev.ts",
    "test:server": "tsx scripts/test.ts --project=server",
    "test:server-dev": "tsx scripts/server-dev.ts",
    "test:autocomplete": "tsx scripts/test.ts --project=desktop autocomplete",
    "test:report": "npx playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@playwright/test": "1.61.1",
    "dotenv": "^17.4.2",
    "playwright": "1.61.1",
    "strip-json-comments": "^3.1.1"
  },
  "devDependencies": {
    "@estruyf/github-actions-reporter": "^1.12.0",
    "@midleman/playwright-reporter": "^0.49.0",
    "@types/node": "^25.9.1",
    "cross-env": "^10.1.0",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3"
  }
}
