;--------------------------------
;Reserve Files

  ;These files should be inserted before other files in the data block
  ;Keep these lines before any File command
  ;Only for solid compression (by default, solid compression is enabled for BZIP2 and LZMA)

;--------------------------------
;Installer Sections

;
; RSTUDIO CHANGE - uninstall previous version
;
; With MULTIUSER_INSTALLMODE_ALLOW_BOTH_INSTALLATIONS 0 the install-mode page
; tells the user that switching between per-user and all-users replaces the
; existing installation, but NsisMultiUser leaves the actual removal to the
; script. Without it the old copy stays on disk, and its Add/Remove entry is
; shadowed because both modes register the same uninstall key name (see
; MULTIUSER_RegistryAddInstallInfo in NsisMultiUser.nsh).
;
; Sets $1 to the opposite mode's uninstall command ('"<path>\Uninstall.exe"
; /allusers|/currentuser', as NsisMultiUser stores UninstallString) and $2 to
; its installation folder; both are empty when there is nothing to remove.
; Invoked via UAC_AsUser_Call so the unelevated outer instance also holds the
; values in case RunCrossModeUninstaller runs there.
Function GetCrossModeUninstaller
  StrCpy $1 ""
  StrCpy $2 ""
  ${If} $MultiUser.InstallMode == "AllUsers"
    ${If} $HasPerUserInstallation = 1
      StrCpy $1 $PerUserUninstallString
      StrCpy $2 $PerUserInstallationFolder
    ${EndIf}
  ${ElseIf} $HasPerMachineInstallation = 1
    StrCpy $1 $PerMachineUninstallString
    StrCpy $2 $PerMachineInstallationFolder
  ${EndIf}
FunctionEnd

; _?= makes the uninstaller run in place so ExecWait actually waits (it also
; means the uninstaller cannot delete itself; the caller cleans up). /uninstall
; suppresses un.onInit's de-elevation relaunch, which would otherwise detach
; the real uninstall from ExecWait. $0 is -1 when the uninstaller failed to
; launch, else its exit code.
Function RunCrossModeUninstaller
  StrCpy $0 -1
  ExecWait '$1 /S /uninstall _?=$2' $0
FunctionEnd

Section "-Remove previous installation"

  ; remove an installation of the opposite mode (per-user vs all-users)
  !insertmacro UAC_AsUser_Call Function GetCrossModeUninstaller ${UAC_SYNCREGISTERS}
  ${If} $1 != ""
    ${If} $MultiUser.InstallMode == "AllUsers"
      ; a per-user installation belongs to the unelevated user; run its
      ; uninstaller in that context so it cleans that user's profile and hive
      DetailPrint "Removing the existing per-user installation..."
      !insertmacro UAC_AsUser_Call Function RunCrossModeUninstaller ${UAC_SYNCREGISTERS}
    ${Else}
      ; removing a per-machine installation requires elevation; NsisMultiUser
      ; already elevated this instance for exactly this case (ALLOW_BOTH 0)
      DetailPrint "Removing the existing all-users installation..."
      Call RunCrossModeUninstaller
    ${EndIf}
    ${If} $0 <> 0
      DetailPrint "Warning: the existing installation could not be removed; continuing."
    ${Else}
      Delete "$2\Uninstall.exe"
      RMDir "$2"
    ${EndIf}
  ${EndIf}

  ; check for uninstaller
  IfFileExists "$INSTDIR\Uninstall.exe" 0 done
  
  ;Run the uninstaller (in place, to allow ExecWait to work properly)
  ClearErrors
  DetailPrint "Removing previous installation..."    
  ; Pass the current install mode so the previous version's uninstaller runs
  ; in the matching context. NsisMultiUser requires /allusers or /currentuser
  ; in silent mode; without it the silent uninstall errors out during upgrades.
  StrCpy $0 "/currentuser"
  ${If} $MultiUser.InstallMode == "AllUsers"
    StrCpy $0 "/allusers"
  ${EndIf}
  ExecWait '"$INSTDIR\Uninstall.exe" /S $0 /uninstall _?=$INSTDIR'

  ; don't remove the uninstaller if we failed
  IfErrors done

  ; remove the uninstaller if it exists
  IfFileExists "$INSTDIR\Uninstall.exe" 0 done
    Delete "$INSTDIR\Uninstall.exe"
    RMDir $INSTDIR 
 
done:

SectionEnd

Section "-Core installation"
  ;Use the entire tree produced by the INSTALL target.  Keep the
  ;list of directories here in sync with the RMDir commands below.
  SetOutPath "$INSTDIR"
  @CPACK_NSIS_FULL_INSTALL@

  ;Store installation folder
  WriteRegStr SHCTX "Software\@CPACK_PACKAGE_VENDOR@\@CPACK_PACKAGE_INSTALL_REGISTRY_KEY@" "" $INSTDIR

  ;Create uninstaller
  WriteUninstaller "$INSTDIR\Uninstall.exe"
  !insertmacro MULTIUSER_RegistryAddInstallInfo
  !insertmacro MULTIUSER_RegistryAddInstallSizeInfo

  ;Create shortcuts
  CreateShortCut "$SMPROGRAMS\RStudio.lnk" "$INSTDIR\.\rstudio.exe"
  
  ;
  ; RSTUDIO CHANGE - add shortcut to diagnostics
  ;
  CreateShortCut "$INSTDIR\resources\app\bin\Run Diagnostics.lnk" \
                 "$WINDIR\system32\cmd.exe" \
                 "/K $\"$INSTDIR\rstudio.exe$\" --run-diagnostics" \
                 "$WINDIR\system32\cmd.exe" 0 \
                 SW_SHOWNORMAL
  
@CPACK_NSIS_EXTRA_INSTALL_COMMANDS@

SectionEnd

;--------------------------------
; Uninstaller init: de-elevate a current-user uninstall, then hand off to NsisMultiUser
Function un.onInit
  ${GetParameters} $R0

  ${GetOptions} $R0 "/uninstall" $R1
  ${ifnot} ${errors}
    StrCpy $RunningFromInstaller 1
  ${else}
    StrCpy $RunningFromInstaller 0
  ${endif}

  ${GetOptions} $R0 "/shelluser" $R1
  ${ifnot} ${errors}
    StrCpy $RunningAsShellUser 1
  ${else}
    StrCpy $RunningAsShellUser 0
  ${endif}

  ; The Add/Remove UninstallString (and the installer's remove-previous step)
  ; carry /allusers or /currentuser. Windows runs uninstallers launched from
  ; Apps & features elevated, and an elevated instance (possibly a different
  ; admin account) resolves $LOCALAPPDATA and HKCU for the wrong user, so a
  ; current-user uninstall is relaunched as the unelevated shell user. An
  ; all-users uninstall stays elevated; de-elevating it would only trigger a
  ; second elevation prompt from MULTIUSER_UNINIT (#14122).
  ${GetOptions} $R0 "/allusers" $R1
  ${ifnot} ${errors}
    StrCpy $RunningAllUsers 1
  ${else}
    StrCpy $RunningAllUsers 0
  ${endif}

  ${ifnot} ${UAC_IsInnerInstance}
  ${andif} $RunningFromInstaller = 0
  ${andif} $RunningAllUsers = 0
    ${if} ${UAC_IsAdmin}
    ${andif} $RunningAsShellUser = 0
      ; Relaunch the uninstaller as the unelevated shell user so it removes the
      ; correct user's files and registry entries. If the relaunch fails, fall
      ; through and continue elevated rather than exit without uninstalling.
      ${StdUtils.ExecShellAsUser} $0 "$INSTDIR\${UNINSTALL_FILENAME}" "open" "/shelluser $R0"
      ${if} $0 == "ok"
      ${orif} $0 == "fallback"
        Quit
      ${endif}
    ${endif}
  ${endif}

  !insertmacro MULTIUSER_UNINIT
FunctionEnd

;--- Add/Remove callback functions: ---
!macro SectionList MacroName
  ;This macro used to perform operation on multiple sections.
  ;List all of your components in following manner here.
@CPACK_NSIS_COMPONENT_SECTION_LIST@
!macroend

Section -FinishComponents
  ;Removes unselected components and writes component status to registry
  !insertmacro SectionList "FinishSection"

!ifdef CPACK_NSIS_ADD_REMOVE
  ; Get the name of the installer executable
  System::Call 'kernel32::GetModuleFileNameA(i 0, t .R0, i 1024) i r1'
  StrCpy $R3 $R0

  ; Strip off the last 13 characters, to see if we have AddRemove.exe
  StrLen $R1 $R0
  IntOp $R1 $R0 - 13
  StrCpy $R2 $R0 13 $R1
  StrCmp $R2 "AddRemove.exe" addremove_installed

  ; We're not running AddRemove.exe, so install it
  CopyFiles $R3 $INSTDIR\AddRemove.exe

  addremove_installed:
!endif
SectionEnd
;--- End of Add/Remove callback functions ---

;--------------------------------
; Component dependencies
Function .onSelChange
  !insertmacro SectionList MaybeSelectionChanged
FunctionEnd

;--------------------------------
;Uninstaller Section

Section "Uninstall"
  ReadRegStr $START_MENU SHCTX \
   "Software\Microsoft\Windows\CurrentVersion\Uninstall\@CPACK_PACKAGE_NAME@" "StartMenu"
  ;MessageBox MB_OK "Start menu is in: $START_MENU"

@CPACK_NSIS_EXTRA_UNINSTALL_COMMANDS@

  ;Remove files we installed.
  ;Keep the list of directories here in sync with the File commands above.
@CPACK_NSIS_DELETE_FILES@
@CPACK_NSIS_DELETE_DIRECTORIES@

!ifdef CPACK_NSIS_ADD_REMOVE
  ;Remove the add/remove program
  Delete "$INSTDIR\AddRemove.exe"
!endif

  ;Remove the uninstaller itself.
  Delete "$INSTDIR\Uninstall.exe"
  !insertmacro MULTIUSER_RegistryRemoveInstallInfo

  ;
  ; RSTUDIO CHANGE - Remove shortcuts
  ;
  Delete "$SMPROGRAMS\RStudio.lnk" 
  Delete "$INSTDIR\resources\app\bin\Run Diagnostics.lnk"
  RMDir /r "$INSTDIR\resources"
  
  ;Remove the installation directory if it is empty.
  RMDir "$INSTDIR"

  ; Remove the registry entries.
  DeleteRegKey SHCTX "Software\@CPACK_PACKAGE_VENDOR@\@CPACK_PACKAGE_INSTALL_REGISTRY_KEY@"

  ; Removes all optional components
  !insertmacro SectionList "RemoveSection_CPack"

  !insertmacro MUI_STARTMENU_GETFOLDER Application $MUI_TEMP

  Delete "$SMPROGRAMS\$MUI_TEMP\Uninstall.lnk"
@CPACK_NSIS_DELETE_ICONS@
@CPACK_NSIS_DELETE_ICONS_EXTRA@

  ;Delete empty start menu parent directories
  StrCpy $MUI_TEMP "$SMPROGRAMS\$MUI_TEMP"

  startMenuDeleteLoop:
    ClearErrors
    RMDir $MUI_TEMP
    GetFullPathName $MUI_TEMP "$MUI_TEMP\.."

    IfErrors startMenuDeleteLoopDone

    StrCmp "$MUI_TEMP" "$SMPROGRAMS" startMenuDeleteLoopDone startMenuDeleteLoop
  startMenuDeleteLoopDone:

  ; If the user changed the shortcut, then uninstall may not work. This should
  ; try to fix it.
  StrCpy $MUI_TEMP "$START_MENU"
  Delete "$SMPROGRAMS\$MUI_TEMP\Uninstall.lnk"
@CPACK_NSIS_DELETE_ICONS_EXTRA@

  ;Delete empty start menu parent directories
  StrCpy $MUI_TEMP "$SMPROGRAMS\$MUI_TEMP"

  secondStartMenuDeleteLoop:
    ClearErrors
    RMDir $MUI_TEMP
    GetFullPathName $MUI_TEMP "$MUI_TEMP\.."

    IfErrors secondStartMenuDeleteLoopDone

    StrCmp "$MUI_TEMP" "$SMPROGRAMS" secondStartMenuDeleteLoopDone secondStartMenuDeleteLoop
  secondStartMenuDeleteLoopDone:

  DeleteRegKey /ifempty SHCTX "Software\@CPACK_PACKAGE_VENDOR@\@CPACK_PACKAGE_INSTALL_REGISTRY_KEY@"

SectionEnd

;--------------------------------
Function .onInit

  ; Guard the running-app check so it runs only in the (unelevated) outer
  ; instance, before MULTIUSER_INIT (which may relaunch elevated).
  ${ifnot} ${UAC_IsInnerInstance}
    ${nsProcess::FindProcess} "rstudio.exe" $R0
    ${If} $R0 = 0
      MessageBox MB_OK|MB_ICONEXCLAMATION "@CPACK_PACKAGE_NAME@ is currently running. Please close it before installing a new version." /SD IDOK
      Abort
    ${EndIf}
    ${nsProcess::Unload}
  ${endif}

  !insertmacro MULTIUSER_INIT

  ; Component status (uses SHCTX set by MULTIUSER_INIT)
  !insertmacro SectionList "InitSection"

FunctionEnd
