<ui:UiBinder xmlns:ui='urn:ui:com.google.gwt.uibinder'
             xmlns:g='urn:import:com.google.gwt.user.client.ui'
             xmlns:hist='urn:import:org.rstudio.studio.client.workbench.views.vcs.dialog'
             xmlns:widget="urn:import:org.rstudio.core.client.widget">

   <ui:style type="org.rstudio.studio.client.workbench.views.vcs.dialog.CommitDetail.DescriptionStyle">
      .summary td:first-child {
         font-weight: bold;
         padding-right: 16px;
      }

      .subject {
         font-weight: bold;
      }

      .summary td div {
         white-space: pre-wrap;
      }

      .summary td {
         padding-bottom: 6px;
      }

      .descriptionPanel {
         max-width: 72ch;
         margin-top: 6px;
         border: 1px solid rgba(128, 128, 128, 0.25);
         border-radius: 4px;
         background-color: rgba(128, 128, 128, 0.06);
         overflow: hidden;
      }

      .descriptionBody {
         padding: 8px 12px;
         white-space: pre-wrap;
      }

      .descriptionBody.clamped {
         display: -webkit-box;
         -webkit-box-orient: vertical;
         -webkit-line-clamp: 4;
         overflow: hidden;
      }

      .descriptionToggle {
         display: block;
         box-sizing: border-box;
         width: 100%;
         padding: 4px 0;
         text-align: center;
         font-size: 90%;
         color: inherit;
         cursor: pointer;
         text-decoration: none;
         border-top: 1px solid rgba(128, 128, 128, 0.25);
         background-color: rgba(128, 128, 128, 0.12);
      }

      .descriptionToggle:hover {
         background-color: rgba(128, 128, 128, 0.2);
         text-decoration: none;
      }

      .toc {

      }
      .detailPanel {
         width: 100%;
      }
      .emptySelectionLabel {
         width: 100%;
         height: 48px;
         margin-top: 80px;
         font-size: 130%;
         font-weight: bold;
         color: #6f6f6f;
         text-align: center;
      }
      .progressPanel {
         width: 100%;
         height: 48px;
         margin-top: 30px;
      }
   </ui:style>

   <g:FlowPanel>
      <!-- Text will be dynamically set to "(No commit selected)" -->
      <g:Label ui:field="emptySelectionLabel_"
               styleName="{style.emptySelectionLabel}"/>

      <g:HTMLPanel ui:field="commitViewPanel_" visible="false">
         <table class="{style.summary}" cellspacing="0" cellpadding="0">
            <tr>
               <td><g:Label ui:field="labelIdDesc_" /></td>
               <td><g:Label ui:field="labelId_" /></td>
            </tr>
            <tr>
               <td>Author</td>
               <td><g:Label ui:field="labelAuthor_" /></td>
            </tr>
            <tr>
               <td>Date (UTC)</td>
               <td><g:Label ui:field="labelDate_" /></td>
            </tr>
            <tr>
               <td>Subject</td>
               <td class="{style.subject}"><g:Label ui:field="labelSubject_" /></td>
            </tr>
            <tr ui:field="parentTableRow_">
               <td>Parent</td>
               <td><g:Label ui:field="labelParent_" /></td>
            </tr>
         </table>
         <g:HTMLPanel ui:field="descriptionPanel_" styleName="{style.descriptionPanel}" visible="false">
            <g:HTML ui:field="labelDescription_" styleName="{style.descriptionBody}" />
            <g:Anchor ui:field="descriptionToggle_" styleName="{style.descriptionToggle}" visible="false" />
         </g:HTMLPanel>
         <hist:SizeWarningWidget ui:field="sizeWarning_"/>
         <g:VerticalPanel ui:field="tocPanel_" styleName="{style.toc}" />
         <g:VerticalPanel ui:field="detailPanel_" styleName="{style.detailPanel}" />

         <widget:ProgressPanel ui:field="progressPanel_" visible="false"
                               styleName="{style.progressPanel}"/>

      </g:HTMLPanel>
   </g:FlowPanel>

</ui:UiBinder>
