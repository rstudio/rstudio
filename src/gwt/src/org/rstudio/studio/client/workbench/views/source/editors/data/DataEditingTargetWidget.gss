.description {
  position: relative;
  top: -1px;
  margin-right: 6px;
}

.statusBar {
  font-size: 10px;
  background-color: #f3f3f3;
  border-top: 1px solid #ccc;
  padding: 3px 0 0 6px;
}

.statusBarDisplayed {
  display: inline;
}

.statusBarOmitted {
  display: inline;
  color: #777;
  margin-left: 4px;
}
