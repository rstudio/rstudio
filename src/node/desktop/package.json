{
  "name": "rstudio",
  "productName": "RStudio",
  "version": "99.9.9",
  "description": "RStudio",
  "main": "./.webpack/main",
  "repository": "https://github.com/rstudio/rstudio",
  "author": "RStudio PBC",
  "license": "AGPL-3.0-only",
  "scripts": {
    "clean": "ts-node scripts/clean.ts",
    "lint": "eslint ./src ./test",
    "typecheck": "tsc --noEmit",
    "package": "npm ci && electron-forge package",
    "start": "electron-forge start -- --no-sandbox",
    "debug": "electron-forge start --inspect-electron",
    "fullstart": "npm install && electron-forge start",
    "test": "electron-mocha --no-sandbox --full-trace --config ./test/unit/mocharc.json",
    "testwip": "electron-mocha -c -g WIP --config ./test/unit/mocharc.json",
    "format": "npx prettier --write . --ignore-path .gitignore",
    "postinstall": "node scripts/postinstall.js && npx electron-rebuild && ts-node scripts/generate.ts",
    "generate": "ts-node scripts/generate.ts",
    "install-fuses": "node scripts/install-fuses.mjs"
  },
  "config": {
    "forge": "./forge.config.js"
  },
  "overrides": {
    "@electron/node-gyp": "npm:node-gyp@^12.0.0",
    "js-yaml": "^4.2.0",
    "launch-editor": "^2.14.1",
    "serialize-javascript": "^7.0.5",
    "tar": "^7.5.16",
    "tmp": "^0.2.7",
    "undici": "^7.28.0",
    "uuid": "$uuid",
    "webpack-dev-server": "^5.2.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "7.11.2",
    "@electron-forge/plugin-webpack": "7.11.2",
    "@electron/packager": "20.0.2",
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "10.0.1",
    "@types/chai": "5.2.3",
    "@types/line-reader": "0.0.37",
    "@types/lodash.debounce": "4.0.9",
    "@types/mocha": "10.0.10",
    "@types/node": "26.1.1",
    "@types/properties-reader": "2.1.3",
    "@types/sinon": "22.0.0",
    "@types/winston-syslog": "2.4.4",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "buffer": "^6.0.3",
    "chai": "6.2.2",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "electron": "42.7.0",
    "electron-mocha": "13.1.0",
    "eslint": "10.7.0",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "globals": "17.7.0",
    "json": "11.0.0",
    "json-schema-to-typescript": "15.0.4",
    "lint-staged": "17.0.8",
    "mocha": "11.7.6",
    "nan": "2.28.0",
    "node-loader": "2.1.0",
    "prettier": "3.9.5",
    "process": "0.11.10",
    "sinon": "22.0.0",
    "style-loader": "4.0.0",
    "ts-loader": "9.6.2",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "vue-loader": "17.4.2",
    "webpack": "5.108.4"
  },
  "dependencies": {
    "@electron/fuses": "2.1.3",
    "@vueuse/core": "14.3.0",
    "crc": "4.3.2",
    "electron-store": "11.0.2",
    "i18next": "26.3.6",
    "line-reader": "0.4.0",
    "lodash.debounce": "4.0.8",
    "net-ipc": "2.2.2",
    "node-abi": "4.33.0",
    "node-addon-api": "8.9.0",
    "properties-reader": "3.0.1",
    "semver": "7.8.5",
    "uuid": "14.0.1",
    "vue": "3.5.39",
    "winston": "3.19.0",
    "winston-syslog": "2.7.1"
  },
  "allowScripts": {
    "electron@42.7.0": true,
    "msgpackr-extract@3.0.3": true,
    "unix-dgram@2.0.6": true
  }
}
