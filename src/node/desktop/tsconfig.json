{
  "compilerOptions": {
    "incremental": true,
    "module": "commonjs",
    "target": "es2022",
    "sourceMap": true,
    "removeComments": true,
    "rootDir": "../..",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "lib": ["es2022", "DOM"],
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules"],
  "ts-node": {
    "transpileOnly": true
  }
}
